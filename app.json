{
  "expo": {
    "name": "EasyReads",
    "slug": "easyread",
    "scheme": "easyread",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "extra": {
      "eas": {
        "projectId": "df76a00c-4eae-4c73-8537-49b9922bb99e"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yomgupta.easyread",
      "icon": "./assets/appstore.png",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "EasyReads sends you a gentle daily reading nudge and a warning before your streak breaks.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.yomgupta.easyread",
      "versionCode": 2,
      "icon": "./assets/icon.png",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/analytics",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4A7C59"
        }
      ]
    ]
  }
}
